{
  "name": "bumpgrade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && next typegen && next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --pretty false",
    "test:browser": "npm run db:migrate:local && npm run cf:build && playwright test",
    "test:runtime-secrets": "node scripts/check-runtime-secret-precedence.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test:runtime-secrets && npm run build && npm run test:browser",
    "cf:build": "rm -rf .next .open-next && npm exec opennextjs-cloudflare build",
    "preview:worker": "wrangler dev",
    "preview": "npm run cf:build && wrangler dev",
    "deploy": "npm run cf:build && scripts/with-cloudflare-env.sh npm exec opennextjs-cloudflare deploy",
    "cf:types": "wrangler types src/worker-configuration.d.ts --include-runtime false",
    "cf:whoami": "scripts/with-cloudflare-env.sh npx --yes wrangler whoami",
    "mobile:ios:validate": "npm --prefix apps/mobile-admin run validate:ios",
    "mobile:ios:smoke": "npm --prefix apps/mobile-admin run ios:smoke",
    "mobile:android:validate": "npm --prefix apps/mobile-admin run validate:android",
    "mobile:android:smoke": "npm --prefix apps/mobile-admin run android:smoke",
    "pr:email": "npm run codex:email-pr --",
    "codex:email-pr": "scripts/with-cloudflare-env.sh node scripts/send-codex-pr-email.mjs",
    "codex:poll-inbox": "node scripts/poll-codex-inbox.mjs",
    "db:migrate:local": "npx --yes wrangler d1 migrations apply bumpgrade-prod --local",
    "db:migrate:remote": "scripts/with-cloudflare-env.sh npx --yes wrangler d1 migrations apply bumpgrade-prod --remote",
    "work-log:add": "node scripts/add-work-log-entry.mjs",
    "for-mark:add": "node scripts/add-mark-attention-item.mjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "typescript": "^5",
    "wrangler": "^4.91.0"
  }
}
